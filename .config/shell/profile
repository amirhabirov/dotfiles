export EDITOR=vim
export PAGER="less -giqx2$~ --incsearch --wordwrap"
export BROWSER=firefox

export XDG_CONFIG_HOME=~/.config
export XDG_DATA_HOME=~/.local/share
export XDG_CACHE_HOME=~/.cache

export XINITRC=$XDG_CONFIG_HOME/x11/xinitrc
export ZDOTDIR=$XDG_CONFIG_HOME/zsh
export GNUPGHOME=$XDG_CONFIG_HOME/gnupg
export PASSWORD_STORE_DIR=$XDG_CONFIG_HOME/password-store
export ARTISTIC_STYLE_OPTIONS=$XDG_CONFIG_HOME/astyle/astylerc

export GOPATH=$XDG_DATA_HOME/go
export GOMODCACHE=$XDG_CACHE_HOME/go/mod
export GOPROXY=direct
export GOSUMDB=off
export GOTELEMETRY=off
export GOTOOLCHAIN=local

white=#ffffea
black=#333333
gray=#d3d3d3

export FZF_DEFAULT_OPTS="--color=\
bg:${white},fg:${black},hl:${black},\
bg+:${gray},fg+:${black},hl+:${black},\
info:${black},prompt:${black},pointer:${gray},\
marker:${black},spinner:${black},header:${black},\
border:${black},label:${black},query:${black},\
gutter:${white},separator:${black}"
